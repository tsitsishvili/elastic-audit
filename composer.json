{
    "name": "tsitsishvili/elastic-audit",
    "description": "Laravel package that logs third-party HTTP traffic (outgoing requests and incoming callbacks) and actor/model activity to a dedicated Elasticsearch cluster, with redaction, queued indexing, sampling, and optional dashboards.",
    "type": "library",
    "keywords": [
        "laravel",
        "elasticsearch",
        "audit",
        "audit-log",
        "audit-trail",
        "logging",
        "http-client",
        "http-logging",
        "activity-log",
        "observability",
        "guzzle",
        "redaction"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0 || ^13.0",
        "elasticsearch/elasticsearch": "^8.5 || ^9.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Tsitsishvili\\ElasticAudit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tsitsishvili\\ElasticAudit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tsitsishvili\\ElasticAudit\\ElasticAuditServiceProvider"
            ],
            "aliases": {
                "HttpLog": "Tsitsishvili\\ElasticAudit\\Facades\\HttpLog",
                "ActivityLog": "Tsitsishvili\\ElasticAudit\\Facades\\ActivityLog"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
